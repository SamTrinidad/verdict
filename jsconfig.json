{
    "$schema": "https://json.schemastore.org/jsconfig",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "target": "ESNext",
        "module": "ESNext",
        "strict": false,
        "checkJs": false,
        "verbatimModuleSyntax": true
    },
    "include": [
        "resources/js/**/*"
    ],
    "exclude": [
        "node_modules",
        "vendor",
        "public",
        "storage",
        "bootstrap/ssr"
    ]
}
